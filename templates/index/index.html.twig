{% extends 'base.html.twig' %}

{% block title %}Weather Dashboard Version_1.0{% endblock %}

{% block body %}

    <div class="bg"></div>

    <div class="container">

        <header class="top">
            <div class="logo">
              <a href="{{ path('app_index') }}">
                <img src="/logo/logo.svg" alt="weather icon">
              </a>
            </div>
            <h1>Weather Dashboard Version 1.0</h1>
            <p>Clean, fast weather overview</p>
        </header>

        <turbo-frame id="the_frame_id">

        <div class="search">
            {{ form_start(form) }}
            {{ form_widget(form.name, {'attr': {'placeholder': 'Search city...'}}) }}
            {{ form_widget(form.submit) }}
            <div class="form-error">
                {{ form_errors(form.name) }}
                {{ form_errors(form) }}
            </div>
            {{ form_end(form) }}
        </div>
        {% if weather %}
                <div class="card map-card">
                    {{ ux_map(
                        center: [weather.geoCodeViewModel.latitude, weather.geoCodeViewModel.longitude],
                        zoom: 12,
                        markers: [
                            { position: [weather.geoCodeViewModel.latitude, weather.geoCodeViewModel.longitude],
                                title: weather.geoCodeViewModel.name,
                                infoWindow: {content: '<h3>' ~ weather.geoCodeViewModel.name ~ '</h3><p>Temperature: ' ~ weather.currentWeatherDto.temperature ~ '°C</p>'}
                            },
                        ],
                        fitBoundsToMarkers: false,
                        attributes: {
                            'data-controller': 'mymap',
                            class: 'dashboard-map',
                            style: 'width:100%; height:550px; border-radius:12px;'
                        }
                    ) }}
                    <div class="map-hint">
                        📍 You can drag and drop the marker anywhere on the map to change location
                    </div>
                </div>

            <section class="grid">
                <div class="card main">
                    <div class="city">{{ weather.geoCodeViewModel.name }}</div>
                    <div class="temp">{{ weather.currentWeatherDto.temperature|number_format(1) }}{{ weather.currentWeatherUnitsDto.temperatureUnit }}</div>
                    <div class="desc">{{ weather.currentWeatherDto.description }}</div>

                    <div class="meta">
                        <div>💨 {{ weather.currentWeatherDto.windSpeed}} {{ weather.currentWeatherUnitsDto.windSpeedUnit }}</div>
                        <div>💧 {{ weather.currentWeatherDto.relativeHumidity }}{{ weather.currentWeatherUnitsDto.relativeHumidityUnit }}</div>
                        <div>🌡️ {{ weather.currentWeatherDto.apparentTemperature|number_format(1) }}{{ weather.currentWeatherUnitsDto.temperatureUnit }} feels</div>
                    </div>
                </div>

                <div class="card small">
                    <div class="label">Humidity</div>
                    <div class="value">{{ weather.currentWeatherDto.relativeHumidity }}{{ weather.currentWeatherUnitsDto.relativeHumidityUnit }}</div>
                </div>

                <div class="card small">
                    <div class="label">Wind</div>
                    <div class="value">{{ weather.currentWeatherDto.windSpeed }} {{ weather.currentWeatherUnitsDto.windSpeedUnit }}</div>
                </div>

                <div class="card small">
                    <div class="label">Pressure</div>
                    <div class="value">{{ weather.currentWeatherDto.surfacePressure }} {{ weather.currentWeatherUnitsDto.surfacePressureUnit }}</div>
                </div>

            </section>

            <section class="forecast">
                <h2>5 Day Forecast</h2>
                <div class="forecast-grid">
                    {% for date in weather.dailyForecastDto.time %}
                        {% set index = loop.index0 %}
                        <div class="forecast-card">
                            <div class="day">{{ weather.dailyForecastDto.time[index].format('D') }}</div>
                            <div class="icon">
                                <img src="/weather-icons/{{ weather.dailyForecastDto.icon(weather.dailyForecastDto.weatherCodes[index]) }}" alt="weather icon">
                            </div>
                            <div class="temps">{{ weather.dailyForecastDto.maxTemperature[index]|number_format(1) }}{{ weather.dailyForecastUnitsDto.temperatureMaxUnit }} / {{  weather.dailyForecastDto.minTemperature[index]|number_format(1) }}{{ weather.dailyForecastUnitsDto.temperatureMinUnit }}</div>
                        </div>
                    {% endfor %}
                </div>
            </section>
        {% else %}

            <div class="empty-state">
                <div class="icon">🌍</div>
                <h2>Weather Dashboard</h2>
                <p>Enter a city above to get real-time weather data and a 5-day forecast.</p>
            </div>

        {% endif %}

        </turbo-frame>
    </div>

{% endblock %}
